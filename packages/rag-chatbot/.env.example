# ai 模型配置（按 provider 动态切换：deepseek / xiaomi / openai / google / zhipu）
# DeepSeek、Xiaomi（OpenAI 兼容）共用：
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY= <your api key>


# 智谱 GLM（zhipu-ai-provider）：默认 https://open.bigmodel.cn/api/paas/v4
# 可选：Z.AI 国际站等自定义 API 前缀，例如 https://api.z.ai/api/paas/v4
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
ZHIPU_API_KEY= <your api key>

# ZHIPU_BASE_URL=
# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY= <your api key>

# pg数据库配置
POSTGRES_URL=postgres://postgres:999000@localhost:5432/chatbot

# better auth 用于认证
BETTER_AUTH_SECRET= <your secret key>

BETTER_AUTH_URL=http://localhost:3000 # Base URL of your app

# github oauth 用于认证
GITHUB_CLIENT_ID= <your github client id>
GITHUB_CLIENT_SECRET= <your github client secret>

# redis 用于流式响应恢复 default: redis://localhost:6379
REDIS_URL= <your redis url>

# serpapi 用于网页搜索 https://serpapi.com/
SERPAPI_API_KEY= <your serpapi api key>